# MemoryBridge environment configuration
# Copy to ~/memorybridge/.env and fill in values

# Notion integration (opt-in)
NOTION_API_TOKEN=your_notion_integration_token_here
NOTION_FLAGGED_DB_ID=your_notion_flagged_database_id_here
NOTION_CONTEXT_PAGE_ID=your_notion_context_page_id_here

# DeepSeek (for extraction)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Anthropic (for escalation resolver)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Data directory override (optional — defaults to ~/memorybridge)
# Set this to move memory.db, analytics.json, inbox/, logs/, and .env to a custom path
MEMORYBRIDGE_DATA=/path/to/custom/data/dir

# ---------------------------------------------------------------------------
# HTTP bridge (remote MCP access via Cloudflare tunnel) — only needed if you
# run the server with MEMORYBRIDGE_TRANSPORT=http.
# ---------------------------------------------------------------------------
# Secret embedded in the capability URL (/{token}/mcp). This is the ONLY auth
# for the internet-exposed bridge — use a strong, unique value (>= 32 chars).
# Generate one with:  python3 -c "import secrets; print(secrets.token_urlsafe(32))"
MEMORYBRIDGE_TOKEN=
# Transport: "stdio" (default, local Claude Desktop) or "http" (remote bridge)
MEMORYBRIDGE_TRANSPORT=stdio
# Port for the HTTP bridge (default 8484)
MEMORYBRIDGE_PORT=8484

# Optional tuning
# MEMORYBRIDGE_RECENCY_DAYS=      # recency window for scoring
# MEMORYBRIDGE_MAX_CONVERSATIONS= # extraction cost cap (default 500; 0 = unlimited)
# MEMORYBRIDGE_RATE_LIMIT=        # HTTP bridge per-IP requests per window (default 120)
# MEMORYBRIDGE_RATE_WINDOW=       # rate-limit window seconds (default 60)
